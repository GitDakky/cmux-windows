{
  "fontFamily": "Cascadia Code",
  "fontSize": 14,
  "themeName": "Default Dark",
  "appThemeName": "Default Dark",
  "uiFontScale": 1.0,
  "defaultShell": "C:\\Program Files\\PowerShell\\7\\pwsh.exe",
  "defaultShellArgs": "-NoLogo",
  "scrollbackLines": 10000,
  "restoreSessionOnStartup": true,
  "confirmOnClose": true,
  "shellProfiles": [
    {
      "name": "PowerShell 7",
      "command": "C:\\Program Files\\PowerShell\\7\\pwsh.exe",
      "arguments": "-NoLogo",
      "isDefault": true
    },
    {
      "name": "Command Prompt",
      "command": "C:\\Windows\\System32\\cmd.exe",
      "arguments": ""
    },
    {
      "name": "WSL",
      "command": "C:\\Windows\\System32\\wsl.exe",
      "arguments": ""
    },
    {
      "name": "Git Bash",
      "command": "C:\\Program Files\\Git\\bin\\bash.exe",
      "arguments": "--login -i"
    }
  ],
  "keyBindings": {},
  "notifications": {
    "enableToastNotifications": true,
    "toastOnlyWhenUnfocused": true,
    "enableTaskbarFlash": true,
    "flashOnlyWhenUnfocused": true,
    "enableIdleDetection": true,
    "idleAttentionSeconds": 90,
    "idleOnlyWhenAgentDetected": true
  },
  "agent": {
    "enabled": false
  },
  "browser": {
    "defaultProfileId": "isolated-default",
    "profiles": [
      {
        "id": "isolated-default",
        "name": "Isolated (agent sandbox)",
        "kind": "embeddedIsolated",
        "scopeToSurface": true,
        "startUrl": "about:blank",
        "isDefault": true
      },
      {
        "id": "project-default",
        "name": "Project (persistent)",
        "kind": "embeddedPersistent",
        "scopeToSurface": false,
        "startUrl": "about:blank"
      },
      {
        "id": "external-default",
        "name": "External browser",
        "kind": "external",
        "startUrl": "about:blank"
      }
    ]
  },
  "updates": {
    "checkOnStartup": true,
    "checkIntervalHours": 24
  }
}
